<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>My Personal Blog</title>
</head>

<body>
    <h1>Welcome to My Personal Blog</h1>
    <hr>

    <h2>บทความล่าสุด</h2>
    <ul>
        <% posts.forEach(post=> { %>
            <li>
                <a href="/article/<%= post.id %>">
                    <strong>
                        <%= post.title %>
                    </strong>
                </a> <br>
                <small>วันที่: <%= post.date %></small>
            </li>
            <br>
            <% }) %>
    </ul>
</body>

</html>